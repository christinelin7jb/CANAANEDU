rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Presence: any signed-in user ──
    match /presence/{uid} {
      allow read, write: if request.auth != null;
    }

    // ── User profiles: any user can read; only write your own ──
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Activity feed: any signed-in user can read/create ──
    match /activityFeed/{docId} {
      allow read, create: if request.auth != null;
    }

    // ── Students: owner + collaborators, plus invitation-accept rule ──
    match /students/{studentId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.get('sharedWith', [])
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // Owner can update anything
        resource.data.ownerId == request.auth.uid ||
        // Existing collaborator can update
        request.auth.uid in resource.data.get('sharedWith', []) ||
        // Accept-invitation rule: recipient may ONLY add their own UID to sharedWith,
        // touching no other fields. This pairs with the sequential accept flow in JS
        // (invitation is marked 'accepted' first, then this update fires).
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWith']) &&
          request.auth.uid in request.resource.data.get('sharedWith', []) &&
          !(request.auth.uid in resource.data.get('sharedWith', []))
        )
      );
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    // ── Invitations ──
    match /invitations/{inviteId} {
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null && (
        // Sender can cancel / modify
        resource.data.fromUid == request.auth.uid ||
        // Recipient can accept or decline (matched by email — case-insensitive via toLowerCase() in JS)
        resource.data.toEmail == request.auth.token.email
      );
      allow delete: if request.auth != null &&
        resource.data.fromUid == request.auth.uid;
    }
  }
}
